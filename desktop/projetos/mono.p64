--[[pod_format="raw",created="2025-12-26 23:52:43",modified="2026-07-05 17:08:46",revision=86]]
function _init()
  player={
    spr_id = 21,
    x = 110,
    y = 80,
    vel = 1, -- velocidade de movimento
    dir = 1, -- 1 = direita, -1 = esquerda    
    life=3
  }
  
  itens = {
    { x=200, y=80,  spr_id=44,  efeito= 1, sfx_id=0 },  -- cura: +1 vida
    { x=280, y=112, spr_id=45,  efeito=-1, sfx_id=1 },  -- dano: -1 vida
    { x=320, y=64,  spr_id=44,  efeito= 1, sfx_id=0 },  -- cura: +1
  }  
  
end

function _update()
  -- testar X separadamente
  local vx = player.x
  local vy = player.y
  
  if btn(0) then vx -= player.vel; player.dir = -1 end
  if btn(1) then vx += player.vel; player.dir = 1 end
  if btn(2) then vy -= player.vel end
  if btn(3) then vy += player.vel end

  -- resolver X independente de Y
  if not colide_mapa(vx, player.y, 8, 8) then
    player.x = vx
  end

  -- resolver Y independente de X
  if not colide_mapa(player.x, vy, 8, 8) then
    player.y = vy
  end

  player.x = mid(10, player.x, 470)
  player.y = mid(10, player.y, 260)
  
  for item in all(itens) do
    if colide_aabb(player.x, player.y, 8, 8, item.x, item.y, 8, 8) then
      player.life += item.efeito  -- aplica +1 ou -1
      sfx(item.sfx_id)           -- toca o som do item
      del(itens, item)           -- remove o item do mundo
    end
  end

  -- garantir que life fique entre 0 e um maximo
  player.life = mid(0, player.life, 9)  
  
end

function _draw()
  cls(0)
  
  -- map(cx, cy, sx, sy, cw, ch)
  -- cx,cy = celula inicial do mapa
  -- sx,sy = posicao na tela
  -- cw,ch = quantidade de celulas a desenhar
  --map(0, 0, 0, 0, 30, 17)
  map()
  
  for item in all(itens) do
    spr(item.spr_id, item.x, item.y)
  end  
  
  -- desenhar o jogador POR CIMA do mapa
  spr(player.spr_id, player.x, player.y, player.dir == -1)
  
  -- desenhar UI com a vida do jogador
  local pos = 0
  for i=1, player.life do 
    pos+= 10  
    spr(43, pos, 10)
  end
  
end

-- retorna true se o pixel (x,y) esta dentro de um tile solido
function solido(x, y)
  local cx = flr(x / 8)
  local cy = flr(y / 8)
  return fget(mget(cx, cy), 0)
end

-- testa os 4 cantos do retangulo do jogador
function colide_mapa(x, y, w, h)
  return solido(x,     y)
      or solido(x+w-1, y)
      or solido(x,     y+h-1)
      or solido(x+w-1, y+h-1)
end

function colide_aabb(ax, ay, aw, ah, bx, by, bw, bh)
  return ax < bx+bw
     and ax+aw > bx
     and ay < by+bh
     and ay+ah > by
end
