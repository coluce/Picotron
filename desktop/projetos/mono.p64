--[[pod_format="raw",created="2025-12-26 23:52:43",modified="2026-07-02 01:09:38",revision=49]]
function _init()
  spr_id = 21
  x = 110
  y = 80
  vel = 1  -- velocidade de movimento
  dir = 1   -- 1 = direita, -1 = esquerda
end

function _update()
  -- testar X separadamente
  local vx = x
  local vy = y
  
  if btn(0) then vx -= vel; dir = -1 end
  if btn(1) then vx += vel; dir = 1 end
  if btn(2) then vy -= vel end
  if btn(3) then vy += vel end

  -- resolver X independente de Y
  if not colide_mapa(vx, y, 8, 8) then
    x = vx
  end

  -- resolver Y independente de X
  if not colide_mapa(x, vy, 8, 8) then
    y = vy
  end

  x = mid(10, x, 470)
  y = mid(10, y, 260)
end

function _draw()
  cls(1)
  
  -- map(cx, cy, sx, sy, cw, ch)
  -- cx,cy = celula inicial do mapa
  -- sx,sy = posicao na tela
  -- cw,ch = quantidade de celulas a desenhar
  --map(0, 0, 0, 0, 30, 17)
  map()
  
  -- desenhar o jogador POR CIMA do mapa
  spr(spr_id, x, y, dir == -1)
  
end

-- retorna true se o pixel (x,y) esta dentro de um tile solido
function solido(x, y)
  local cx = flr(x / 8)
  local cy = flr(y / 8)
  return fget(mget(cx, cy), 0)
end

-- testa os 4 cantos do retangulo do jogador
function colide_mapa(x, y, w, h)
  return solido(x,     y)
      or solido(x+w-1, y)
      or solido(x,     y+h-1)
      or solido(x+w-1, y+h-1)
end
