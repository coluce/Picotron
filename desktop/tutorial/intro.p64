--[[pod_format="raw",created="2026-06-28 01:04:57",modified="2026-06-28 01:15:33",revision=7]]
function _init()
  -- jogador
  px, py = 240, 135
  vel = 3
  
  -- alvo
  novo_alvo()
  
  -- placar
  pontos = 0
  tempo  = 600  -- 10 segundos a 60fps
  estado = "jogando"
end

function novo_alvo()
  -- posicao aleatoria na tela
  tx = rnd(440) + 20
  ty = rnd(230) + 20
end

function _update()
  if estado == "jogando" then
    -- mover jogador
    if btn(0) then px -= vel end
    if btn(1) then px += vel end
    if btn(2) then py -= vel end
    if btn(3) then py += vel end
    px = mid(10, px, 470)
    py = mid(10, py, 260)
    
    -- colisao: distancia entre jogador e alvo
    local dx = px - tx
    local dy = py - ty
    if dx*dx + dy*dy < 20*20 then
      pontos += 1
      sfx(0)   -- toca sfx 0 (opcional)
      novo_alvo()
    end
    
    -- contagem regressiva
    tempo -= 1
    if tempo <= 0 then
      estado = "fim"
    end
    
  elseif estado == "fim" then
    if btnp(4) then  -- Z para reiniciar
      _init()
    end
  end
end

function _draw()
  cls(1)
  
  if estado == "jogando" then
    -- desenhar alvo
    circfill(tx, ty, 10, 8)   -- vermelho
    circ(tx, ty, 10, 7)       -- borda branca
    
    -- desenhar jogador
    circfill(px, py, 8, 12)   -- azul claro
    
    -- HUD
    print("pontos: "..pontos, 10, 10, 7)
    print("tempo: "..flr(tempo/60), 380, 10, 7)
    
  elseif estado == "fim" then
    print("FIM DE JOGO!", 190, 120, 8)
    print("pontos: "..pontos, 210, 140, 7)
    print("[Z] para jogar de novo", 170, 160, 6)
  end
end
